# GroupMe Bot Configuration
# Get your Bot ID from https://dev.groupme.com/bots
GROUPME_BOT_ID=your_bot_id_here

# Server Configuration
PORT=3000

# Random Schedule Configuration
# Messages will be sent at random times between START_HOUR and END_HOUR
# Time is in 24-hour format (12 = 12 PM, 15 = 3 PM)
# Default: Between 12:00 PM and 12:05 PM EST
START_HOUR=12
END_HOUR=15

# Note: Timezone is fixed to America/New_York (EST) for consistency